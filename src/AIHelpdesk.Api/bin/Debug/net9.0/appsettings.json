{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Serilog": {
      "MinimumLevel": {
        "Default": "Information",
        "Override": {
          "Microsoft": "Warning",
          "Microsoft.AspNetCore": "Warning"
        }
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=aihelpdesk;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "SuperSecretKeyForJwtTokenGeneration2024!@#$%^&*()AtLeast32Chars",
    "Issuer": "AIHelpdesk",
    "Audience": "AIHelpdesk",
    "AccessTokenExpiryMinutes": "15"
  },
  "Cors": {
    "Origins": ["http://localhost:5173", "http://localhost:3000"]
  },
  "AI": {
    "Endpoint": "https://api.openai.com/v1/",
    "ApiKey": "",
    "ChatModel": "gpt-4o-mini",
    "EmbeddingModel": "text-embedding-3-small"
  },
  "KnowledgeBase": {
